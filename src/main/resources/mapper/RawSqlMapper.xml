<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.skyleew.relationmapping.mapper.RawSqlMapper"> <!-- 命名空间必须匹配 -->

    <select id="executeRawSQL" parameterType="java.util.HashMap" resultType="map">
        ${sql}
    </select>

    <select id="executeBindRawSQL" parameterType="java.util.HashMap" resultType="map">
        ${sqlTemplate}
        ${conditions}
    </select>
</mapper>

